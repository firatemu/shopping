# ========================================
# SoftShopping — Environment Variables
# ========================================
# Copy this file to .env.development and fill in the values.

# ---- Application ----
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# ---- Database (PostgreSQL) — yerel npm run dev:api (DATABASE_URL) ----
DATABASE_URL=postgresql://textilepos:textilepos_dev_pass@localhost:5432/textilepos?schema=public
DB_PORT=5432
DB_NAME=textilepos
DB_USER=textilepos
DB_PASSWORD=textilepos_dev_pass

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT Authentication ----
# IMPORTANT: Must be at least 32 characters
JWT_SECRET=change_me_to_a_random_32_char_string_in_production
JWT_REFRESH_SECRET=change_me_to_another_random_32_char_string_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ---- NGINX ----
NGINX_PORT=80

# ---- Object Storage (S3 / Cloudflare R2 / MinIO) ----
# Used for product images and file uploads.
# Without these vars, uploads fall back to local /uploads/ path (diskStorage).
# Local development: use MinIO (see docker-compose.yml)
# Production: use Cloudflare R2 (endpoint = https://<account-id>.r2.cloudflarestorage.com)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=textilepos-uploads
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_PUBLIC_URL=http://localhost:9000/textilepos-uploads

# ---- Redis Cache ----
# Optional: cache-aside prefix (default: textilepos)
CACHE_KEY_PREFIX=textilepos

# ---- Sentry Error Monitoring ----
# Leave empty to disable (development). Set in production.
SENTRY_DSN=

# ---- OpenAI API ----
OPENAI_API_KEY=your_openai_api_key_here

# ---- Docker Compose (opsiyonel; kopyala: cp .env.example .env) ----
#
# Senaryo tablosu (WEB / Next proxy):
# | Senaryo                          | NEXT_PUBLIC_API_URL | API_DEV_PROXY_TARGET (web .env veya compose)   |
# |----------------------------------|--------------------|-----------------------------------------------|
# | Hepsi yerelde (npm dev:web+api)  | /api/v1            | (boş) veya http://127.0.0.1:$API_PORT         |
# | docker compose up api web        | /api/v1            | http://api:4000 (compose varsayılanı)          |
# | Web konteyner, API sadece host’ta| /api/v1            | http://host.docker.internal:<host_publish_port>|
#
# Docker stack (kilitli sözleşme: AGENTS.md §2.5):
# postgres/redis ana makineye port AÇMAZ (yalnızca api↔db iç ağ).
# Bu yüzden yerel PostgreSQL/Redis ile çakışma olmaz. DB bakımı: docker compose exec postgres psql -U textilepos -d textilepos
# Sadece API (:4000) ve Web (:3000) host’a yayınlanır (API_PORT / WEB_PORT).
# Port çakışırsa: API_PORT=4001 WEB_PORT=3001 docker compose up -d ...
#
# Tam compose stack: Web proxy varsayılanı `http://api:4000`dır (iç ağ, 4000).
# Hibrit için kök .env ile örn. API_DEV_PROXY_TARGET=http://host.docker.internal:4000
# npm run docker:fresh — compose down, 3000–4001 port temizliği, postgres+redis+api+web yeniden build/up (Windows’ta WSL ile).
# npm run ports:clean — sadece compose down + port temizliği.
# Tüm çalışan Docker konteynerlerini durdurmak (dikkat): STOP_ALL_DOCKER=1 bash scripts/clean-dev-ports.sh
WEB_PORT=3003
API_PORT=4002

