# ========================================
# TextilePOS — Environment Variables
# ========================================
# Copy this file to .env.development and fill in the values.

# ---- Application ----
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://textilepos:textilepos_dev_pass@localhost:5432/textilepos?schema=public
DB_PORT=5432
DB_NAME=textilepos
DB_USER=textilepos
DB_PASSWORD=textilepos_dev_pass

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT Authentication ----
# IMPORTANT: Must be at least 32 characters
JWT_SECRET=change_me_to_a_random_32_char_string_in_production
JWT_REFRESH_SECRET=change_me_to_another_random_32_char_string_prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ---- NGINX ----
NGINX_PORT=80

# ---- OpenAI API ----
OPENAI_API_KEY=your_openai_api_key_here
