{
  "name": "textile-pos",
  "version": "1.0.0",
  "private": true,
  "description": "TextilePOS — Multi-tenant SaaS POS for clothing retail stores",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:web:wsl": "node scripts/dev-web.cjs",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "local:stack": "node scripts/run-local-stack.cjs",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "docker:up": "docker compose up -d --build postgres redis api web",
    "docker:dev": "docker compose up -d --build postgres redis api web",
    "docker:db": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.1.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "typescript": "5.9.3"
  }
}
