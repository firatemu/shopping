{
  "expo": {
    "name": "TextilePOS Mobile",
    "owner": "azemfirats-organization",
    "slug": "softshopping",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "textilepos",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.textilepos.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Barkod okumak için kamera kullanılır."
      }
    },
    "android": {
      "package": "com.textilepos.app",
      "versionCode": 2,
      "permissions": ["CAMERA", "INTERNET", "VIBRATE"]
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod okumak için kamera kullanılır."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000/api/v1",
      "eas": {
        "projectId": "17daf42a-5ab3-4ba5-b98c-02ab79b22103"
      }
    }
  }
}
