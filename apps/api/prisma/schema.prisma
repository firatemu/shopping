// Prisma Schema — TextilePOS
// Phase 1 Foundation: tenants, users, products, variants, orders, payments, campaigns
// Architecture Rules enforced:
//   Rule #1: Every table has tenant_id UUID NOT NULL
//   Rule #3: Soft delete (deleted_at, deleted_by, is_deleted) on all business tables
//   Rule #4: Optimistic locking (version) on product_variants and orders
//   Rule #5: Monetary fields use Decimal(12,2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  STORE_MANAGER
  SENIOR_SALES
  SALES_STAFF
  CASHIER
  ACCOUNTANT
}

enum OrderStatus {
  PENDING
  COMPLETED
  PARTIALLY_RETURNED
  FULLY_RETURNED
  CANCELLED
}

enum PaymentType {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  OPEN_ACCOUNT
  GIFT_VOUCHER
  MIXED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER
  RESERVATION
  RELEASE
}

enum CampaignType {
  X_FOR_Y
  PERCENTAGE
  SECOND_ITEM
  FIXED_AMOUNT
  CATEGORY
}

enum GiftVoucherStatus {
  ACTIVE
  PARTIALLY_USED
  FULLY_USED
  EXPIRED
  BLACKLISTED
}

enum GiftVoucherSource {
  CORPORATE
  RETURN_REFUND
}

enum LedgerMovementType {
  SALE
  RETURN
  PAYMENT_CASH
  PAYMENT_CARD
  PAYMENT_TRANSFER
  PAYMENT_CHECK
  PAYMENT_OUT_CASH
  PAYMENT_OUT_TRANSFER
  PAYMENT_OUT_CHECK
  PURCHASE
  OPENING_BALANCE
  ADJUSTMENT
}

enum CustomerType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum CashRegisterStatus {
  OPEN
  CLOSED
  ADJUSTED
}

// =============================================
// TENANT
// =============================================

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique @db.VarChar(3) // 3-character tenant code for barcodes
  domain      String?  @unique
  isActive    Boolean  @default(true) @map("is_active")
  settings    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users             User[]
  products          Product[]
  orders            Order[]
  sizeSets          SizeSet[]
  productCategories ProductCategory[]
  productBrands     ProductBrand[]
  productColors     ProductColor[]
  expenseCategories ExpenseCategory[]

  @@map("tenants")
}

// =============================================
// USER & AUTH
// =============================================

model User {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String
  username       String
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  role           UserRole  @default(SALES_STAFF)
  isActive       Boolean   @default(true) @map("is_active")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedBy      String?   @map("deleted_by") @db.Uuid
  isDeleted      Boolean   @default(false) @map("is_deleted")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================
// PRODUCT & VARIANTS
// =============================================

model Product {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String
  description  String?
  brand        String?
  category     String?
  subcategory  String?
  season       String?
  gender       String?   // Erkek, Kadın, Unisex, Çocuk
  supplierCode String?   @map("supplier_code") @db.VarChar(64)
  supplierId   String?   @map("supplier_id") @db.Uuid
  costPrice    Decimal   @map("cost_price") @db.Decimal(12, 2)
  salePrice    Decimal   @map("sale_price") @db.Decimal(12, 2)
  kdvRate      Decimal   @map("kdv_rate") @db.Decimal(5, 2) // 0, 10, 20
  imageUrl     String?   @map("image_url")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by") @db.Uuid
  isDeleted    Boolean   @default(false) @map("is_deleted")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  supplier  Customer?        @relation(fields: [supplierId], references: [id])
  variants  ProductVariant[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, supplierId])
  @@map("products")
}

model ProductVariant {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  productId      String    @map("product_id") @db.Uuid
  barcode        String    @db.VarChar(16)
  color          String
  colorCode      String    @map("color_code") @db.VarChar(3)
  size           String
  sizeCode       String    @map("size_code") @db.VarChar(2)
  stockQuantity  Int       @default(0) @map("stock_quantity")
  reservedQty    Int       @default(0) @map("reserved_qty")
  minStockLevel  Int       @default(5) @map("min_stock_level")
  costPrice      Decimal?  @map("cost_price") @db.Decimal(12, 2) // Override product cost
  salePrice      Decimal?  @map("sale_price") @db.Decimal(12, 2) // Override product price
  version        Int       @default(0) // Optimistic locking (Rule #4)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedBy      String?   @map("deleted_by") @db.Uuid
  isDeleted      Boolean   @default(false) @map("is_deleted")

  product        Product         @relation(fields: [productId], references: [id])
  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([barcode])
  @@map("product_variants")
}

model SizeSet {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   // e.g., "Yetişkin Üst Beden", "Çocuk Alt Beden"
  sizes     Json     // ["XS","S","M","L","XL","XXL"]
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("size_sets")
}

// =============================================
// PRODUCT CATALOG MASTERS (categories, brands, colors)
// =============================================

model ProductCategory {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.Uuid
  isDeleted Boolean   @default(false) @map("is_deleted")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryTree")

  @@index([tenantId])
  @@index([tenantId, parentId])
  @@map("product_categories")
}

model ProductBrand {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  code      String    @db.VarChar(16)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.Uuid
  isDeleted Boolean   @default(false) @map("is_deleted")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("product_brands")
}

model ProductColor {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  code      String    @db.VarChar(6)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.Uuid
  isDeleted Boolean   @default(false) @map("is_deleted")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("product_colors")
}

// =============================================
// INVENTORY
// =============================================

model StockMovement {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  variantId       String            @map("variant_id") @db.Uuid
  type            StockMovementType
  quantity        Int               // Positive for IN, negative for OUT
  previousQty     Int               @map("previous_qty")
  newQty          Int               @map("new_qty")
  orderId         String?           @map("order_id") @db.Uuid
  reason          String?
  createdBy       String            @map("created_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id])
  order   Order?         @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([tenantId, variantId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// =============================================
// ORDERS & PAYMENTS
// =============================================

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  orderNumber     String      @map("order_number") // [YYYYMMDD]-[TenantCode]-[DailySeq(5)]
  customerId      String?     @map("customer_id") @db.Uuid
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  discountTotal   Decimal     @default(0) @map("discount_total") @db.Decimal(12, 2)
  kdvTotal        Decimal     @default(0) @map("kdv_total") @db.Decimal(12, 2)
  grandTotal      Decimal     @map("grand_total") @db.Decimal(12, 2)
  notes           String?
  version         Int         @default(0) // Optimistic locking (Rule #4)
  soldBy          String      @map("sold_by") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")
  deletedBy       String?     @map("deleted_by") @db.Uuid
  isDeleted       Boolean     @default(false) @map("is_deleted")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  stockMovements         StockMovement[]
  giftVouchersFromReturn GiftVoucher[] @relation("GiftVoucherSourceOrder")

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  variantId      String   @map("variant_id") @db.Uuid
  quantity       Int
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  kdvRate        Decimal  @map("kdv_rate") @db.Decimal(5, 2)
  kdvAmount      Decimal  @map("kdv_amount") @db.Decimal(12, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(12, 2)
  campaignId     String?  @map("campaign_id") @db.Uuid
  returnedQty    Int      @default(0) @map("returned_qty")
  createdAt      DateTime @default(now()) @map("created_at")

  order   Order          @relation(fields: [orderId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  orderId         String      @map("order_id") @db.Uuid
  type            PaymentType
  amount          Decimal     @db.Decimal(12, 2)
  reference       String?     // Card authorization ref, bank transfer ref, voucher code, etc.
  giftVoucherId   String?     @map("gift_voucher_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at")

  order         Order         @relation(fields: [orderId], references: [id])
  giftVoucher   GiftVoucher?  @relation(fields: [giftVoucherId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([giftVoucherId])
  @@map("payments")
}

// =============================================
// CAMPAIGNS
// =============================================

model Campaign {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  name         String
  type         CampaignType
  description  String?
  rules        Json         // Campaign-specific rules (e.g., { buyQty: 3, payQty: 2 })
  priority     Int          @default(50) @db.SmallInt // 1-100, higher = more priority
  isCombinable Boolean      @default(false) @map("is_combinable")
  startDate    DateTime     @map("start_date")
  endDate      DateTime     @map("end_date")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  deletedBy    String?      @map("deleted_by") @db.Uuid
  isDeleted    Boolean      @default(false) @map("is_deleted")

  @@index([tenantId])
  @@index([tenantId, startDate, endDate])
  @@map("campaigns")
}

// =============================================
// GIFT VOUCHERS
// =============================================

model GiftVoucher {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  code            String
  source          GiftVoucherSource  @default(CORPORATE)
  companyName     String?            @map("company_name")
  notes           String?
  sourceOrderId   String?            @map("source_order_id") @db.Uuid
  initialBalance  Decimal            @map("initial_balance") @db.Decimal(12, 2)
  currentBalance  Decimal            @map("current_balance") @db.Decimal(12, 2)
  status          GiftVoucherStatus  @default(ACTIVE)
  expiresAt       DateTime?          @map("expires_at")
  createdBy       String             @map("created_by") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  sourceOrder       Order?    @relation("GiftVoucherSourceOrder", fields: [sourceOrderId], references: [id])
  paymentRedemptions Payment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, sourceOrderId])
  @@map("gift_vouchers")
}

// =============================================
// LABEL TEMPLATES
// =============================================

model LabelTemplate {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(120)
  description String?
  widthMm     Decimal   @default(100) @map("width_mm") @db.Decimal(8, 2)
  heightMm    Decimal   @default(60) @map("height_mm") @db.Decimal(8, 2)
  design      Json
  zpl         String
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by") @db.Uuid
  isDeleted   Boolean   @default(false) @map("is_deleted")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("label_templates")
}

// =============================================
// AUDIT LOG
// =============================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  action     String
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// =============================================
// CUSTOMER (CARİ HESAP)
// =============================================

model Customer {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  code              String    @map("code") @db.VarChar(32)
  type              CustomerType @default(CUSTOMER)
  name              String
  surname           String?
  companyName       String?   @map("company_name")
  taxId             String?   @map("tax_id")
  taxOffice         String?   @map("tax_office")
  phone             String?
  email             String?
  country           String    @default("Türkiye")
  address           String?
  city              String?
  district          String?
  neighborhood      String?   @map("neighborhood")
  postalCode        String?   @map("postal_code") @db.VarChar(10)
  birthDate         DateTime? @map("birth_date")
  creditLimit       Decimal   @default(0) @map("credit_limit") @db.Decimal(12, 2)
  defaultDueDays    Int       @default(0) @map("default_due_days")
  openingBalance    Decimal   @default(0) @map("opening_balance") @db.Decimal(12, 2)
  currentBalance    Decimal   @default(0) @map("current_balance") @db.Decimal(12, 2)
  creditLimitAction String    @default("WARN") @map("credit_limit_action") // WARN or BLOCK
  iban              String?   @map("iban") @db.VarChar(34)
  bankName          String?   @map("bank_name") @db.VarChar(120)
  paymentNotes      String?   @map("payment_notes")
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by") @db.Uuid
  isDeleted         Boolean   @default(false) @map("is_deleted")

  ledgerMovements LedgerMovement[]
  products        Product[]

  @@unique([tenantId, code])
  @@unique([tenantId, taxId])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, type])
  @@map("customers")
}

model LedgerMovement {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  customerId  String             @map("customer_id") @db.Uuid
  type        LedgerMovementType
  amount      Decimal            @db.Decimal(12, 2)
  balanceAfter Decimal           @map("balance_after") @db.Decimal(12, 2)
  orderId     String?            @map("order_id") @db.Uuid
  documentType String?           @map("document_type")
  documentNo   String?           @map("document_no")
  description String?
  reference   String?
  createdBy   String             @map("created_by") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@map("ledger_movements")
}

// =============================================
// CASH REGISTER (KASA)
// =============================================

model CashRegisterSession {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  cashierId       String             @map("cashier_id") @db.Uuid
  openingBalance  Decimal            @map("opening_balance") @db.Decimal(12, 2)
  closingBalance  Decimal?           @map("closing_balance") @db.Decimal(12, 2)
  physicalCount   Decimal?           @map("physical_count") @db.Decimal(12, 2)
  difference      Decimal?           @db.Decimal(12, 2)
  totalCash       Decimal            @default(0) @map("total_cash") @db.Decimal(12, 2)
  totalCard       Decimal            @default(0) @map("total_card") @db.Decimal(12, 2)
  totalTransfer   Decimal            @default(0) @map("total_transfer") @db.Decimal(12, 2)
  totalSales      Int                @default(0) @map("total_sales")
  totalReturns    Int                @default(0) @map("total_returns")
  status          CashRegisterStatus @default(OPEN)
  openedAt        DateTime           @default(now()) @map("opened_at")
  closedAt        DateTime?          @map("closed_at")
  closedBy        String?            @map("closed_by") @db.Uuid
  notes           String?

  adjustments CashRegisterAdjustment[]

  @@index([tenantId])
  @@index([tenantId, cashierId])
  @@index([tenantId, openedAt])
  @@map("cash_register_sessions")
}

model CashRegisterAdjustment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  reason      String
  approvedBy  String   @map("approved_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  session CashRegisterSession @relation(fields: [sessionId], references: [id])

  @@index([tenantId])
  @@index([sessionId])
  @@map("cash_register_adjustments")
}

// =============================================
// EXPENSE (GELİR/GİDER)
// =============================================

enum ExpenseType {
  INCOME
  EXPENSE
}

/// Gelir veya gider için tanımlı kategori (aynı isim hem INCOME hem EXPENSE için ayrı kayıt olabilir).
model ExpenseCategory {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  name      String
  kind      ExpenseType
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  expenses Expense[]

  @@unique([tenantId, name, kind])
  @@index([tenantId])
  @@index([tenantId, kind])
  @@map("expense_categories")
}

model Expense {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  type        ExpenseType
  categoryId  String      @map("category_id") @db.Uuid
  amount      Decimal     @db.Decimal(12, 2)
  description String?
  date        DateTime    @default(now())
  isRecurring Boolean     @default(false) @map("is_recurring")
  recurringDay Int?       @map("recurring_day") @db.SmallInt
  reference   String?
  createdBy   String      @map("created_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")
  deletedBy   String?     @map("deleted_by") @db.Uuid
  isDeleted   Boolean     @default(false) @map("is_deleted")

  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, categoryId])
  @@map("expenses")
}

// =============================================
// SALES TARGET (PERSONEL PERFORMANS)
// =============================================

model SalesTarget {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  period      String   // e.g. "2026-05", "2026-Q2"
  targetAmount Decimal @map("target_amount") @db.Decimal(12, 2)
  achievedAmount Decimal @default(0) @map("achieved_amount") @db.Decimal(12, 2)
  commissionRate Decimal @default(0) @map("commission_rate") @db.Decimal(5, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId, period])
  @@index([tenantId])
  @@map("sales_targets")
}

// =============================================
// NOTIFICATION (BİLDİRİM)
// =============================================

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  tenantId  String              @map("tenant_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean             @default(false) @map("is_read")
  readAt    DateTime?           @map("read_at")
  metadata  Json?
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([tenantId, userId])
  @@index([tenantId, userId, isRead])
  @@map("notifications")
}

// =============================================
// BRANCH (ÇOKLU ŞUBE)
// =============================================

model Branch {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  code      String    @db.VarChar(5)
  address   String?
  city      String?
  phone     String?
  isMain    Boolean   @default(false) @map("is_main")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  isDeleted Boolean   @default(false) @map("is_deleted")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model StockTransfer {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  fromBranchId    String         @map("from_branch_id") @db.Uuid
  toBranchId      String         @map("to_branch_id") @db.Uuid
  status          TransferStatus @default(PENDING)
  notes           String?
  createdBy       String         @map("created_by") @db.Uuid
  receivedBy      String?        @map("received_by") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  completedAt     DateTime?      @map("completed_at")

  items StockTransferItem[]

  @@index([tenantId])
  @@index([tenantId, fromBranchId])
  @@index([tenantId, toBranchId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id          String @id @default(uuid()) @db.Uuid
  transferId  String @map("transfer_id") @db.Uuid
  variantId   String @map("variant_id") @db.Uuid
  quantity    Int
  receivedQty Int    @default(0) @map("received_qty")

  transfer StockTransfer @relation(fields: [transferId], references: [id])

  @@index([transferId])
  @@map("stock_transfer_items")
}

// =============================================
// INTEGRATION (E-TİCARET)
// =============================================

enum IntegrationType {
  TRENDYOL
  HEPSIBURADA
  N11
  AMAZON
  CUSTOM_API
}

enum IntegrationStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

model Integration {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  type        IntegrationType
  status      IntegrationStatus @default(DISCONNECTED)
  config      Json              // API keys, store IDs, etc. (encrypted at app level)
  lastSyncAt  DateTime?         @map("last_sync_at")
  syncErrors  Int               @default(0) @map("sync_errors")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@unique([tenantId, type])
  @@index([tenantId])
  @@map("integrations")
}
