{
  "name": "@textile-pos/desktop",
  "version": "1.0.0",
  "description": "SoftShopping Desktop — Electron + ÖKC bridge",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.textilepos.desktop",
    "productName": "SoftShopping",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}