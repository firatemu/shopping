# SoftShopping — Development Environment
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3003

# Database
DATABASE_URL=postgresql://textilepos:textilepos_dev_pass@localhost:5432/textilepos?schema=public
DB_PORT=5432
DB_NAME=textilepos
DB_USER=textilepos
DB_PASSWORD=textilepos_dev_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=dev_jwt_secret_change_in_production_32ch
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_prod_32ch
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# NGINX
NGINX_PORT=80

# OpenAI API — anahtarı burada tutmayın; yerel kullanımda export veya ayrı gizli dosya kullanın.
OPENAI_API_KEY=

# ---- Object Storage (S3 / Cloudflare R2 / MinIO) ----
# Local dev without MinIO: leave STORAGE_ENDPOINT empty to use disk fallback.
STORAGE_ENDPOINT=
STORAGE_BUCKET=textilepos-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=

# ---- Redis Cache ----
CACHE_KEY_PREFIX=textilepos

# Not: Next.js ortam dosyaları `apps/web/` altından yüklenir (`apps/web/.env.development`, `.env.local`).
